<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.architectcgz.file.infrastructure.repository.mapper.FileRecordMapper">
    
    <!-- 结果映射 -->
    <resultMap id="fileRecordResultMap" type="com.architectcgz.file.infrastructure.repository.po.FileRecordPO">
        <id property="id" column="id"/>
        <result property="appId" column="app_id"/>
        <result property="userId" column="user_id"/>
        <result property="storageObjectId" column="storage_object_id"/>
        <result property="originalFilename" column="original_name"/>
        <result property="storagePath" column="storage_path"/>
        <result property="fileSize" column="file_size"/>
        <result property="contentType" column="content_type"/>
        <result property="fileHash" column="file_hash"/>
        <result property="accessLevel" column="access_level"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>
    
    <!-- 动态查询条件 SQL 片段 -->
    <sql id="queryConditions">
        <where>
            <if test="tenantId != null and tenantId != ''">
                AND app_id = #{tenantId}
            </if>
            <if test="userId != null and userId != ''">
                AND user_id = #{userId}
            </if>
            <if test="contentType != null and contentType != ''">
                AND content_type = #{contentType}
            </if>
            <if test="accessLevel != null">
                AND access_level = #{accessLevel}
            </if>
            <if test="startTime != null">
                AND created_at &gt;= #{startTime}
            </if>
            <if test="endTime != null">
                AND created_at &lt;= #{endTime}
            </if>
            <if test="minSize != null">
                AND file_size &gt;= #{minSize}
            </if>
            <if test="maxSize != null">
                AND file_size &lt;= #{maxSize}
            </if>
        </where>
    </sql>
    
    <!-- 根据查询条件查找文件记录列表 -->
    <select id="selectByQuery" resultMap="fileRecordResultMap">
        SELECT id, app_id, user_id, storage_object_id, original_name, storage_path, file_size,
               content_type, file_hash, access_level, status, created_at, updated_at
        FROM file_records
        <include refid="queryConditions"/>
        <if test="sortBy != null and sortBy != ''">
            ORDER BY
            <choose>
                <when test="sortBy == 'createdAt'">created_at</when>
                <when test="sortBy == 'fileSize'">file_size</when>
                <when test="sortBy == 'originalFilename'">original_name</when>
                <otherwise>created_at</otherwise>
            </choose>
            <choose>
                <when test="sortOrder != null and sortOrder.toLowerCase() == 'asc'">ASC</when>
                <otherwise>DESC</otherwise>
            </choose>
        </if>
        LIMIT #{size} OFFSET #{page} * #{size}
    </select>
    
    <!-- 根据查询条件统计文件记录数量 -->
    <select id="countByQuery" resultType="long">
        SELECT COUNT(*)
        FROM file_records
        <include refid="queryConditions"/>
    </select>

    <!-- 存储统计聚合查询：总文件数、总存储空间、按 access_level 分组计数 -->
    <select id="selectStorageStatistics" resultType="com.architectcgz.file.domain.model.StorageStatisticsAggregation">
        SELECT
            COUNT(*)                                                          AS totalFiles,
            COALESCE(SUM(file_size), 0)                                       AS totalStorageBytes,
            COUNT(CASE WHEN access_level = 'public'  THEN 1 END)              AS publicFiles,
            COUNT(CASE WHEN access_level = 'private' THEN 1 END)              AS privateFiles
        FROM file_records
    </select>

    <!-- 按 content_type 分组统计文件数量 -->
    <select id="selectFileCountByContentType" resultType="com.architectcgz.file.domain.model.ContentTypeCount">
        SELECT
            content_type AS contentType,
            COUNT(*)     AS fileCount
        FROM file_records
        GROUP BY content_type
    </select>

    <!-- 按租户（app_id）分组统计存储空间 -->
    <select id="selectStorageByTenant" resultType="com.architectcgz.file.domain.model.TenantStorageAggregation">
        SELECT
            app_id                        AS appId,
            COALESCE(SUM(file_size), 0)   AS storageBytes
        FROM file_records
        GROUP BY app_id
    </select>

</mapper>
