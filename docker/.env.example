# =====================================================
# File Service Docker Environment Variables
# =====================================================

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=file_service

# RustFS Configuration
RUSTFS_ROOT_USER=fileservice
RUSTFS_ROOT_PASSWORD=fileservice123
RUSTFS_BUCKET=platform-files

# File Service Configuration
FILE_SERVICE_PORT=8089
DB_URL=jdbc:postgresql://postgres:5432/file_service
DB_USERNAME=postgres
DB_PASSWORD=postgres

# S3 Configuration
S3_ENDPOINT=http://rustfs:9000
S3_ACCESS_KEY=fileservice
S3_SECRET_KEY=fileservice123
S3_BUCKET=platform-files
S3_REGION=us-east-1

# Storage Configuration
STORAGE_TYPE=s3
MAX_FILE_SIZE=104857600

# Java Options
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC

# Logging
LOG_LEVEL=INFO
